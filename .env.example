APP_NAME=WB AI Platform
APP_ENV=development
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
POSTGRES_DB=wb_ai
POSTGRES_USER=wb_user
